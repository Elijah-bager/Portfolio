<div class="wakeup-container">
  <h1>Welcome</h1>

  <% if user_signed_in? %>
    <p class="welcome">Welcome back, <%= current_user.name %>!</p>
    <p class="user-info">You are logged in and ready to explore.</p>
    
    <div class="action-buttons">
      <%= link_to "Log Out", destroy_user_session_path, class: "btn btn-secondary", data: { turbo_method: :delete } %>
    </div>

  <% else %>
    <p>Please log in or sign up to get started.</p>
    
    <div class="auth-links">
      <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary" %>
      <%= link_to "Log In", new_user_session_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
