<h1>Edit Trip</h1>

<div class="trip-form">
  <%= form_with model: @trip do |f| %>
    <% if @trip.errors.any? %>
      <div class="error-messages">
        <h3><%= pluralize(@trip.errors.count, "error") %> prevented this trip from being saved:</h3>
        <ul>
          <% @trip.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-field">
      <%= f.label :name %>
      <%= f.text_field :name, required: true %>
    </div>

    <div class="form-field">
      <%= f.label :start_date %>
      <%= f.datetime_local_field :start_date, required: true %>
    </div>

    <div class="form-field">
      <%= f.label :end_date %>
      <%= f.datetime_local_field :end_date, required: true %>
    </div>

    <div class="form-actions">
      <%= f.submit "Update Trip", class: "btn btn-primary" %>
      <%= link_to "Cancel", @trip, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
