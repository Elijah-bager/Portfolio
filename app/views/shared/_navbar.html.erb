<nav class="site-nav">
  <div class="nav-inner">
    <div class="nav-brand">
      <%= link_to "Elden Trips", root_path, class: "nav-logo" %>
    </div>

    <ul class="nav-links">
      <li class="nav-item"><%= link_to "Trips", trips_path %></li>
      <li class="nav-item"><%= link_to "New Trip", new_trip_path %></li>
      <li class="nav-item"><%= link_to "Users", users_path %></li>
    </ul>

    <div class="nav-right">
      <% if user_signed_in? %>
        <span class="nav-user">Signed in as <%= current_user.name || current_user.email %></span>
